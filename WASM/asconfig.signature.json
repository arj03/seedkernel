{
  "entries": ["assembly/signature/index.ts"],
  "targets": {
    "debug": {
      "outFile": "build/signature.debug.wasm",
      "textFile": "build/signature.debug.wat",
      "sourceMap": true,
      "debug": true,
      "exportRuntime": true
    },
    "release": {
      "outFile": "build/signature.wasm",
      "textFile": "build/signature.wat",
      "optimizeLevel": 3,
      "shrinkLevel": 2,
      "converge": false,
      "noAssert": true,
      "exportRuntime": true
    }
  },
  "options": {
    "bindings": "raw"
  }
}
